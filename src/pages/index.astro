		<style>
			*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
			html { height: 100%; }
			body {
				min-height: 100%;
				-webkit-font-smoothing: antialiased;
				-moz-osx-font-smoothing: grayscale;
				font-feature-settings: 'liga' 1, 'calt' 1;
				font-family: 'JetBrains Mono', monospace;
				font-size: 13px;
				background: #fff;
				color: #000;
			}
			.icon { width: 1.25rem; height: 1.25rem; display: block; }

			.page {
				max-width: 560px;
				margin: 0 auto;
				padding: 4rem 1.5rem 3rem;
			}

			.hero {
				margin-bottom: 1.25rem;
				padding-bottom: 1rem;
				border-bottom: 1px dashed #999;
			}

			.name {
				font-size: 18px;
				font-weight: 700;
				letter-spacing: -0.02em;
			}

			.hero-socials {
				display: flex;
				gap: 0.5rem;
				margin-top: 0.5rem;
			}

			.hero-socials a + a::before {
				content: '| ';
				color: #999;
				margin-right: 0.5rem;
				text-decoration: none;
				display: inline-block;
			}

			.hero-socials .icon {
				width: 0; height: 0; overflow: hidden; position: absolute;
			}

			.hero-socials a {
				font-size: 12px;
				color: #000;
				text-decoration: none;
			}

			.hero-socials a[aria-label="GitHub"]::after { content: '-> github'; text-decoration: underline; }
			.hero-socials a[aria-label="Twitter / X"]::after { content: '-> twitter'; text-decoration: underline; }
			.hero-socials a[aria-label="LinkedIn"]::after { content: '-> linkedin'; text-decoration: underline; }
			.hero-socials a[aria-label="Email"]::after { content: '-> email'; text-decoration: underline; }

			.about {
				margin-top: 0.75rem;
				line-height: 1.55;
				padding-bottom: 1.25rem;
				border-bottom: 1px dashed #999;
			}

			.about p + p { margin-top: 0.5rem; }

			.about a {
				color: #000;
				text-decoration: underline;
				text-underline-offset: 2px;
			}

			.work {
				margin-top: 1.25rem;
			}

			.work h2 {
				font-size: 13px;
				font-weight: 700;
				margin-bottom: 0.5rem;
			}

			.work-list {
				display: flex;
				flex-direction: column;
				gap: 0.1rem;
			}

			.work-item {
				text-decoration: none;
				color: #000;
				display: block;
				line-height: 1.55;
			}
			.work-title {
				text-decoration: underline;
				text-underline-offset: 2px;
			}

			.work-title::before {
				content: '-  ';
				color: #999;
				text-decoration: none;
				display: inline-block;
				white-space: pre;
			}

			.work-desc {
				color: #999;
			}
			.work-desc::before { content: '  '; }

			@media (max-width: 480px) {
				.page { padding: 2.5rem 1.25rem 2rem; }
			}
		</style>

		<script>
			const user = 'nickslevine';
			const domain = 'gmail.com';
			const mailto = 'mailto:' + user + '@' + domain;
			document.getElementById('email-link').href = mailto;
			document.querySelector('.email-cta').href = mailto;
		</script>
	</body>
</html>
